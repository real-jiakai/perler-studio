---
import "../styles/global.css";
import PerlerStudio from "../components/PerlerStudio";
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<meta
			name="description"
			content="Turn any image into a Perler bead pattern with a bead-accurate color palette, pegboard grid and shopping list."
		/>
		<title>Perler Studio — Bead Pattern Maker</title>
	</head>
	<body class="min-h-screen bg-neutral-50 text-foreground antialiased">
		<header class="border-b bg-white">
			<div class="mx-auto flex max-w-6xl items-center gap-3 px-4 py-4">
				<svg width="28" height="28" viewBox="0 0 28 28" aria-hidden="true">
					<circle cx="8" cy="8" r="6" fill="#C62A34" />
					<circle cx="8" cy="8" r="2.2" fill="#872028" />
					<circle cx="20" cy="8" r="6" fill="#2554A7" />
					<circle cx="20" cy="8" r="2.2" fill="#193971" />
					<circle cx="8" cy="20" r="6" fill="#F5DF00" />
					<circle cx="8" cy="20" r="2.2" fill="#A79800" />
					<circle cx="20" cy="20" r="6" fill="#108551" />
					<circle cx="20" cy="20" r="2.2" fill="#0B5A37" />
				</svg>
				<div>
					<h1 class="text-lg font-semibold leading-tight">Perler Studio</h1>
					<p class="text-sm text-muted-foreground">
						Turn any image into a fuse-bead pattern
					</p>
				</div>
			</div>
		</header>
		<main class="mx-auto max-w-6xl px-4 py-6">
			<PerlerStudio client:load />
		</main>
		<footer
			class="mx-auto max-w-6xl px-4 pb-8 text-center text-xs text-muted-foreground"
		>
			Everything runs in your browser — images never leave your device. Colors
			match the complete current Perler® catalog (103 colors,
			community-measured values). Standard pegboards are 29×29 pegs; midi
			beads are ~5&nbsp;mm.
		</footer>
	</body>
</html>
